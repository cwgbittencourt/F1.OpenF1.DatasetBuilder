# Caminho da configuracao do pipeline
CONFIG_PATH=/app/config/config.yaml

# Diretorios de persistencia
DATA_DIR=/app/data
LOG_DIR=/app/logs
CHECKPOINT_DIR=/app/checkpoints
ARTIFACTS_DIR=/app/artifacts

# OpenF1
OPENF1_BASE_URL=https://api.openf1.org/v1

# MLflow (em outro container)
REGISTER_MLFLOW=true
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=OpenF1Dataset
MLFLOW_ENABLE_SYSTEM_METRICS_LOGGING=true
MLFLOW_SYSTEM_METRICS_SAMPLING_INTERVAL=1
MLFLOW_SYSTEM_METRICS_SAMPLES_BEFORE_LOGGING=1
MLFLOW_REGISTER_MODEL=true
MLFLOW_REGISTER_MODEL_PREFIX=OpenF1

# Gold/questions: NLQ via DuckDB (LLM -> SQL -> execucao)
GOLD_QUESTIONS_DUCKDB=true
# Top N padrao usado nos rankings por setor (DuckDB).
# Se quiser separar, use os campos especificos abaixo.
# GOLD_QUESTIONS_TOP=20
# GOLD_QUESTIONS_SECTOR_TOP=20
# GOLD_QUESTIONS_OVERALL_TOP=20

# Artifact store (MinIO/S3 usado pelo MLflow)
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123456
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# Silencia aviso do GitPython no container
GIT_PYTHON_REFRESH=quiet
